<script>
/* ═══ 3D VIEWER INITIALIZATION ═══ */
window.addEventListener('load', function() {
  var container = document.getElementById('viewer3d');
  if (!container) return;
  function fallback() {
    var ld = document.getElementById('viewer3d-loading');
    if (ld) ld.innerHTML = '<img src="griffon photo 2/03 griffon all.png" style="width:100%;height:100%;object-fit:contain;padding:8px;">';
  }
  if (typeof THREE==='undefined'||typeof THREE.FBXLoader==='undefined'||typeof THREE.OrbitControls==='undefined') { fallback(); return; }
  
  var W = container.clientWidth || 360, H = container.clientHeight || 280;
  var scene = new THREE.Scene(); 
  scene.background = new THREE.Color(0x120906);
  
  var cam = new THREE.PerspectiveCamera(42, W/H, 1, 5000); 
  cam.position.set(0, 100, 300);
  
  var rend = new THREE.WebGLRenderer({antialias: true});
  rend.setSize(W, H); 
  rend.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  rend.shadowMap.enabled = true; 
  container.innerHTML = ''; 
  container.appendChild(rend.domElement);
  
  scene.add(new THREE.AmbientLight(0xffe8d0, 0.7));
  var d1 = new THREE.DirectionalLight(0xffe0c0, 1.4); d1.position.set(150, 250, 200); scene.add(d1);
  var d2 = new THREE.DirectionalLight(0x7080ff, 0.3); d2.position.set(-150, 60, -150); scene.add(d2);
  var d3 = new THREE.DirectionalLight(0xe07a3f, 0.8); d3.position.set(0, -80, -250); scene.add(d3);
  
  var ctrl = new THREE.OrbitControls(cam, rend.domElement);
  ctrl.enableDamping = true; ctrl.dampingFactor = 0.07; ctrl.minDistance = 60; ctrl.maxDistance = 800;
  ctrl.maxPolarAngle = Math.PI * 0.88; ctrl.autoRotate = true; ctrl.autoRotateSpeed = 1.5;
  rend.domElement.addEventListener('pointerdown', function(){ ctrl.autoRotate = false; });
  
  var loader = new THREE.FBXLoader();
  loader.load('griffon photo 2/03 griffon.fbx',
    function(obj){
      var box = new THREE.Box3().setFromObject(obj);
      var sz = box.getSize(new THREE.Vector3());
      var sc = 190 / Math.max(sz.x, sz.y, sz.z);
      var ctr = box.getCenter(new THREE.Vector3());
      
      obj.scale.setScalar(sc); 
      obj.position.copy(ctr.multiplyScalar(-sc));
      obj.traverse(function(c){ 
          if(c.isMesh) {
              c.castShadow = true; 
              c.receiveShadow = true;
          }
      });
      scene.add(obj);
      
      var ld = document.getElementById('viewer3d-loading'); 
      if(ld) ld.style.display = 'none';
    },
    function(xhr){
      if(!xhr.total) return;
      var pct = Math.round(xhr.loaded / xhr.total * 100);
      var ld = document.getElementById('viewer3d-loading');
      if(ld){
          var sp = ld.querySelector('span');
          if(sp) sp.textContent = 'Загрузка ' + pct + '%';
      }
    },
    function(e){
        console.warn('3D Load Error:', e);
        fallback();
    }
  );
  
  window.addEventListener('resize', function() {
      var w = container.clientWidth, h = container.clientHeight;
      cam.aspect = w/h; cam.updateProjectionMatrix(); rend.setSize(w, h);
  });
  
  (function anim(){
      requestAnimationFrame(anim); 
      ctrl.update(); 
      rend.render(scene, cam);
  })();
});
</script>
